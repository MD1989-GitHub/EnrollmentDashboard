@model SearchFilterViewModel

@{
    ViewData["Title"] = "Enrollment Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4">Enrollment Dashboard</h2>

    <!-- 1. SUMMARY STATISTICS CARDS -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-light border-dark h-100 text-center shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-muted uppercase">Total Enrollments</h6>
                    <h2 class="display-6 font-weight-bold">@Model.TotalCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light border-primary h-100 text-center shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-primary uppercase">Active</h6>
                    <h2 class="display-6 font-weight-bold text-primary">@Model.ActiveCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light border-success h-100 text-center shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-success uppercase">Completed</h6>
                    <h2 class="display-6 font-weight-bold text-success">@Model.CompletedCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-light border-danger h-100 text-center shadow-sm">
                <div class="card-body">
                    <h6 class="card-title text-danger uppercase">Withdrawn</h6>
                    <h2 class="display-6 font-weight-bold text-danger">@Model.WithdrawnCount</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. SEARCH & FILTER FORM -->
    <div class="card p-3 mb-4 shadow-sm bg-white">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label font-weight-bold">Start Date</label>
                <input type="date" name="StartDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label font-weight-bold">End Date</label>
                <input type="date" name="EndDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label font-weight-bold">Status</label>
                <select name="Status" class="form-select">
                    <option value="">-- All Statuses --</option>
                    <!-- Explicit evaluation helper to check what status option is active -->
                    <option value="Active" selected="@(Model.Status == EnrollmentStatus.Active ? "selected" : null)">Active</option>
                    <option value="Completed" selected="@(Model.Status == EnrollmentStatus.Completed ? "selected" : null)">Completed</option>
                    <option value="Withdrawn" selected="@(Model.Status == EnrollmentStatus.Withdrawn ? "selected" : null)">Withdrawn</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">Filter</button>
                <a asp-action="Index" class="btn btn-secondary w-100">Reset</a>
            </div>
        </form>
    </div>

    <!-- 3. LIST OF ENROLLMENTS TABLE -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Participant</th>
                        <th>Program</th>
                        <th>Enrollment Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Enrollments != null && Model.Enrollments.Any())
                    {
                        foreach (var item in Model.Enrollments)
                        {
                            <tr>
                                <td>@(item.Participant != null ? $"{item.Participant.FirstName} {item.Participant.LastName}" : "N/A")</td>
                                <td>@(item.Program != null ? item.Program.ProgramName : "N/A")</td>
                                <td>@item.EnrollmentDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @* Dynamic badge styling depending on context state *@
                                    <span class="badge @(item.Status == EnrollmentStatus.Active ? "bg-primary" : item.Status == EnrollmentStatus.Completed ? "bg-success" : "bg-danger")">
                                        @item.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">No enrollment records match your search criteria.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
