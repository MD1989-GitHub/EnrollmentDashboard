@model EnrollmentDashboardApplication.Models.Enrollment

@{
    ViewData["Title"] = "Enrollment Details";
}

<div class="container mt-4">
    <!-- Header with Action Buttons -->
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h2 class="mb-1">Enrollment Record</h2>
            <small class="text-muted">ID: #@Model.EnrollmentId</small>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- LEFT COLUMN: Enrollment Core & Program Details -->
        <div class="col-md-6">
            <!-- Enrollment Status Card -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="card-title mb-0">Enrollment Overview</h5>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.Status == EnrollmentStatus.Active? "bg-primary" : Model.Status == EnrollmentStatus.Completed ? "bg-success" : "bg-danger")">
                                @Model.Status
                            </span>
                        </dd>

                        <dt class="col-sm-4 mt-2">Enrollment Date</dt>
                        <dd class="col-sm-8 mt-2">@Model.EnrollmentDate.ToString("dd MMMM yyyy")</dd>
                    </dl>
                </div>
            </div>

            <!-- Program Information Card -->
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0 text-secondary">Program Details</h5>
                </div>
                <div class="card-body">
                    @if (Model.Program != null)
                    {
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Program Name</dt>
                            <dd class="col-sm-8 text-primary font-weight-bold">@Model.Program.ProgramName</dd>
                            
                            <dt class="col-sm-4 mt-2">Program Code</dt>
                            <dd class="col-sm-8 mt-2">PROG-@Model.Program.ProgramId.ToString("D3")</dd>
                        </dl>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No assigned program data available.</p>
                    }
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN: Participant Profile -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0 text-secondary">Participant Profile</h5>
                </div>
                <div class="card-body">
                    @if (Model.Participant != null)
                    {
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; font-size: 20px;">
                                @Model.Participant.FirstName[0]
                            </div>
                            <div class="ms-3">
                                <h5 class="mb-0">@Model.Participant.FirstName @Model.Participant.LastName</h5>
                                <small class="text-muted">ID: #@Model.Participant.ParticipantId</small>
                            </div>
                        </div>

                        <dl class="row mb-0 pt-2 border-top">
                            <dt class="col-sm-4">Email Address</dt>
                            <dd class="col-sm-8">
                                <a href="mailto:@Model.Participant.Email">@Model.Participant.Email</a>
                            </dd>
                        </dl>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No profile record associated with this enrollment.</p>
                    }
                </div>
            </div>
        </div>

        <!-- FULL WIDTH ROW: Notes Block -->
        <div class="col-12">
            <div class="card shadow-sm border-warning">
                <div class="card-header bg-warning bg-opacity-10 text-dark">
                    <h5 class="card-title mb-0">Administrative Notes</h5>
                </div>
                <div class="card-body bg-light bg-opacity-25">
                    @* 
                        CRITICAL SECURITY PROTOCOL:
                        We use standard Razor syntax @Model.Notes because Razor automatically 
                        HTML-encodes the string. This prevents Cross-Site Scripting (XSS) 
                        vulnerabilities if a user injected script tags into the text field.
                    *@
                    @if (!string.IsNullOrWhiteSpace(Model.Notes))
                    {
                        <p class="mb-0 text-dark style="white-space: pre-line;"">@Model.Notes</p>
                    }
                    else
                    {
                        <em class="text-muted">No administrative notes recorded for this file.</em>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
